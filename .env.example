# ============================================
# Video Agent 环境变量配置
# 阿里云语音 + Kimi 版本 (AccessKey 方式)
# ============================================

# ----------- 1. Kimi 大模型 (Moonshot) -----------
# 获取地址: https://platform.moonshot.cn/
# 用于: 翻译、标题生成
MOONSHOT_API_KEY=your_moonshot_api_key_here

# ----------- 2. 阿里云语音服务 -----------
# 获取 AccessKey: https://ram.console.aliyun.com/manage/ak
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret

# 创建项目获取 AppKey: https://nls-portal.console.aliyun.com/
ALIYUN_TTS_APP_KEY=your_tts_app_key_here
ALIYUN_ASR_APP_KEY=your_asr_app_key_here

# ----------- 3. Web UI 密码（可选） -----------
WEBUI_PASSWORD=admin123

# ----------- 4. 代理配置（访问 YouTube 必需） -----------
# 详细配置见 docs/PROXY_SETUP.md

# HTTP/HTTPS 代理
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 或 SOCKS5 代理
# ALL_PROXY=socks5://127.0.0.1:1080

# 注：本项目专注于内容生成，视频发布功能将在独立项目中实现
