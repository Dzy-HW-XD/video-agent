# ============================================
# Video Agent - GitHub 配置模板
# 
# 使用说明：
# 1. 复制此文件为 .env:  cp .env.github .env
# 2. 在 .env 文件中填入你的真实 API Key
# 3. .env 文件已被 .gitignore 忽略，不会上传到 GitHub
# ============================================

# ----------- 1. Kimi 大模型 (Moonshot) -----------
# 获取地址: https://platform.moonshot.cn/
MOONSHOT_API_KEY=your_moonshot_api_key_here

# ----------- 2. 其他可选 LLM API -----------
# DeepSeek: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 智谱 AI: https://open.bigmodel.cn/
# ZHIPU_API_KEY=your_zhipu_api_key_here

# OpenAI: https://platform.openai.com/
# OPENAI_API_KEY=your_openai_api_key_here

# ----------- 3. Web UI 密码（可选） -----------
WEBUI_PASSWORD=your_secure_password_here

# ----------- 4. 代理配置（访问 YouTube 需要） -----------
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
